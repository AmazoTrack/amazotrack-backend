generator client {
  provider = "prisma-client-js"
}
 
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
enum CompanyType {
  geradora
  destinadora
}
 
enum WasteClass {
  I
  II_A
  II_B
}
 
enum WasteStatus {
  gerado
  coletado
  transportado
  destinado
}
 
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  passwordHash String
  createdAt DateTime @default(now())
 
  wastes    Waste[]
}
 
model Company {
  id                Int      @id @default(autoincrement())
  corporateName     String
  cnpj              String   @unique
  type              CompanyType
 
  licenseNumber     String?
  issuingAgency     String?
  licenseExpiry     DateTime?
  acceptedWasteTypes String?
 
  phone             String?
  email             String?
 
  createdAt         DateTime @default(now())
 
  generatedWastes   Waste[]
  receivedMtrs      MTR[]
}
 
model Waste {
  id          Int        @id @default(autoincrement())
  code        String?
  description String
  quantity    Float
  unit        String
  sector      String
 
  class       WasteClass
  status      WasteStatus @default(gerado)
 
  createdAt   DateTime   @default(now())
  deletedAt   DateTime?
 
  userId      Int
  companyId   Int
 
  user        User       @relation(fields: [userId], references: [id])
  company     Company    @relation(fields: [companyId], references: [id])
 
  movements   Movement[]
  mtr         MTR?
}
 
model Movement {
  id          Int        @id @default(autoincrement())
  toState     WasteStatus
  notes       String?
  transporter String?
  destinationDate DateTime?
 
  createdAt   DateTime   @default(now())
 
  wasteId     Int
  waste       Waste      @relation(fields: [wasteId], references: [id])
}
 
model MTR {
  id              Int      @id @default(autoincrement())
  number          String   @unique
  transporter     String
  issueDate       DateTime @default(now())
 
  wasteId         Int      @unique
  destinationId   Int
 
  waste           Waste    @relation(fields: [wasteId], references: [id])
  destination     Company @relation(fields: [destinationId], references: [id])
}