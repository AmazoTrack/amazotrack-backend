# ─── Banco de Dados ──────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amazotrack"

# ─── Autenticação JWT ────────────────────────────
# Chave secreta para assinar tokens (trocar em produção!)
JWT_SECRET="trocar-em-producao-chave-segura-aqui"

# ─── Servidor ────────────────────────────────────
# Railway injeta PORT automaticamente. Localmente usa 3000.
PORT=3000
